# ─── AncestorTree — Environment Configuration ─────────────────────────────
# Copy this file to .env.local and fill in the values.
# DO NOT commit .env.local to git.

# ─── Option A: Supabase Cloud (production / staging) ──────────────────────
# Get from: Supabase Dashboard → Settings → API
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # ⚠️ SECRET – server only

# ─── Option B: Local Development (Supabase CLI + Docker) ──────────────────
# Run `pnpm local:setup` to start Docker and auto-generate these values.
# Default values shown below match the Supabase CLI defaults.
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<paste from: supabase status>
SUPABASE_SERVICE_ROLE_KEY=<paste from: supabase status>

# Set to "true" when running locally (optional, used for UI hints)
NEXT_PUBLIC_LOCAL_DEV=true

# ─── SMTP (Supabase Auth email — bắt buộc cho OTP login) ───────────────────
# Production: dùng Gmail App Password hoặc SendGrid SMTP.
# Local dev: dùng Mailpit (built-in, email catcher tại http://localhost:54324)
#            Mailpit nghe SMTP ở cổng 1025 trong Docker network.
#
# LOCAL DEV (Mailpit — chạy cùng `supabase start`):
SMTP_HOST=supabase_inbucket_ancestor-tree-local
SMTP_PORT=1025
SMTP_USER=admin
SMTP_PASS=admin
SMTP_SENDER_EMAIL=noreply@giapha.local
SMTP_SENDER_NAME=Gia Phả Điện Tử
#
# PRODUCTION (Gmail App Password — bỏ comment 5 dòng dưới):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password    # Gmail App Password (không phải mật khẩu thường)
# SMTP_SENDER_EMAIL=noreply@yourdomain.com
# SMTP_SENDER_NAME=Gia Phả Điện Tử

# ─── Vercel Cron (required for keep-alive on Supabase free tier) ────────────
# Generate with: openssl rand -hex 32
# CRON_SECRET=your-cron-secret-here

# ─── Clan Customization (optional) ──────────────────────────────────────────
# Change these to customize the app for your own clan/family.
# If not set, defaults to "Họ Đặng" / "Họ Đặng làng Kỷ Các".
# NEXT_PUBLIC_CLAN_NAME=Họ Nguyễn
# NEXT_PUBLIC_CLAN_FULL_NAME=Họ Nguyễn làng ABC, Quảng Nam
